{
  "id": "@node",
  "name": "Node Runtime",
  "description": "Local/no-download Node runtime provider used by Service Lasso managed services.",
  "version": "0.1.0",
  "enabled": true,
  "executable": "node",
  "args": ["--version"],
  "env": {
    "NODE_ENV": "development"
  },
  "urls": [
    {
      "label": "docs",
      "url": "https://nodejs.org",
      "kind": "external"
    }
  ]
}
